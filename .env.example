# Copy to .env (compose) or .env.local (next dev) and fill in.
# .env / *.local are gitignored — never commit real secrets.

# REQUIRED: HMAC key that signs session cookies. Generate with:
#   openssl rand -hex 32
AUTH_SECRET=

# Session cookie "Secure" flag. Empty = auto-detect from request protocol
# (works for HTTP on a LAN and HTTPS behind a proxy). Force with true/false.
# Symptom if wrong: login/setup creates a user but you can't stay logged in
# over plain HTTP (browser drops the Secure cookie).
AUTH_COOKIE_SECURE=

# Optional — where runtime state (users.json, config.json) is stored/created.
# Keep it OUTSIDE the repo/image; it's gitignored and never pushed. Defaults to
# ./data. In Docker this maps to the mounted volume at /app/data.
OPENCHATBOX_DATA_DIR=

# Optional — Single Sign-On via Microsoft Entra ID / OIDC / on-prem AD (ADFS).
# Leave blank to disable the "Mit Firmen-Account anmelden" button.
# Auth.js-style names (preferred):
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
# Tenant id. When set it both builds the default v2.0 endpoints AND restricts
# sign-in to that organization (the token's `tid` claim must match).
AZURE_AD_TENANT_ID=
# Legacy fallback names (still accepted if the Auth.js names are unset):
#   ENTRA_CLIENT_ID / ENTRA_CLIENT_SECRET / ENTRA_TENANT_ID
# Optional role mapping from the Entra "roles" claim (case-insensitive contains):
#   ENTRA_ADMIN_ROLE (default "admin"), ENTRA_POWERUSER_ROLE (default "poweruser")
# Override the endpoints for generic OIDC / AD (else derived from the tenant id):
OIDC_AUTHORIZE_URL=
OIDC_TOKEN_URL=
